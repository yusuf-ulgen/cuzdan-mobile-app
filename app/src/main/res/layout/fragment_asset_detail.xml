<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">


    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_icon"
        android:padding="10dp"
        android:src="@drawable/ic_chevron_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurface" />


    <TextView
        android:id="@+id/text_title_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="@string/detail_title"
        android:textColor="?attr/colorOnSurface"
        android:textSize="22sp"
        android:transitionName="shared_asset_name"
        app:layout_constraintBottom_toTopOf="@id/text_portfolio_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/text_portfolio_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="Portföy: Ana Portföy"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_title_detail" />

    <ImageView
        android:id="@+id/iv_asset_icon_detail"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="2dp"
        android:transitionName="shared_asset_icon"
        android:src="@drawable/ic_asset_placeholder"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_portfolio_name" />

    <ImageButton
        android:id="@+id/btn_alert"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_icon"
        android:padding="12dp"
        android:src="@drawable/ic_notifications"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:tint="?attr/colorPrimary" />

    <ImageButton
        android:id="@+id/btn_delete"
        android:visibility="gone"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_icon"
        android:padding="12dp"
        android:src="@drawable/ic_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:tint="?attr/colorPrimary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_asset_icon_detail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Chart Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="210dp"
                app:cardBackgroundColor="?attr/surfaceGlassStrong"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/text_current_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="₺0.00"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="26sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_price_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="+0.00%"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/text_current_price"
                        app:layout_constraintStart_toEndOf="@id/text_current_price"
                        app:layout_constraintTop_toTopOf="@id/text_current_price" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/priceChart"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="44dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/text_current_price" />

                    <ProgressBar
                        android:id="@+id/progressBarChart"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="@id/priceChart"
                        app:layout_constraintEnd_toEndOf="@id/priceChart"
                        app:layout_constraintStart_toStartOf="@id/priceChart"
                        app:layout_constraintTop_toTopOf="@id/priceChart" />                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/chartRangeToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@+id/btnRange1D"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1D"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="@string/chart_range_1d"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1W"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="@string/chart_range_1w"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1M"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="@string/chart_range_1m"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1Y"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="@string/chart_range_1y"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOutline" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>


                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/detail_quantity_cost"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardBackgroundColor="?attr/surfaceGlassStrong"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_transaction_amount"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/textCurrentAmountHeld"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eldeki: 0.00"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/textAmountLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_unit"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/editAmount"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_search_bar"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?android:attr/textColorSecondary" />


                    <LinearLayout
                        android:id="@+id/layoutCostContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/detail_unit_cost_optional"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editCost"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_search_bar"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="16dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleTransactionType"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnBuy">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuy"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/detail_buy"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface"
                    app:strokeColor="?attr/colorOutline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSell"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/detail_sell"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface"
                    app:strokeColor="?attr/colorOutline" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="4dp"
                android:backgroundTint="?attr/colorPrimary"
                android:fontFamily="sans-serif-black"
                android:text="@string/detail_save"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
